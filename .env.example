# Decision Recall — environment template
#
# Copy to .env and fill in:
#   cp .env.example .env
#
# .env is gitignored and never committed.

# GitHub Personal Access Token (classic)
# Required scopes for private repo create + push:
#   - repo (Full control of private repositories)
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub username (the account that owns the repo)
GITHUB_USER=your-github-username

# Repo name (will be created as <GITHUB_USER>/<GITHUB_REPO>)
GITHUB_REPO=decision-recall
